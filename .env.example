# =========================================================
# ADELANTE EUROVILLAS — Variables de entorno
# Copia este archivo como .env.local y rellena los valores.
# NUNCA subas .env.local a Git (ya está en .gitignore).
# =========================================================

# --- Supabase ---
# Obtén estos valores en: https://supabase.com → tu proyecto → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://XXXXXXXXXXXXXXXX.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
# La service_role key NUNCA va con prefijo NEXT_PUBLIC_ (es solo servidor)
SUPABASE_SERVICE_ROLE_KEY=eyXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# --- Email (Resend) ---
# Obtén la API key en: https://resend.com → API Keys
# El dominio avade.org debe estar verificado en Resend para enviar desde @avade.org
RESEND_API_KEY=re_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# --- Email de destino de formularios ---
# A qué buzón llegan las solicitudes y mensajes del formulario de contacto
CONTACT_EMAIL=informacion@avade.org

# --- URL del sitio ---
# En local: http://localhost:3000 | En producción: https://avade.org
NEXT_PUBLIC_SITE_URL=http://localhost:3000
